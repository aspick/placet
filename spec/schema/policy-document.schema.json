{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/aspick/placet/main/spec/schema/policy-document.schema.json",
  "title": "Placet Policy Document",
  "description": "placet の Policy 定義の正規形 (canonical form)。YAML で記述されたドキュメントも、このデータモデルにパースされた上で本スキーマに適合しなければならない。スキーマで表現できない意味的制約（policy 名の一意性、attachment からの参照整合性）は spec/README.md を参照。",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "policies", "attachments"],
  "properties": {
    "version": {
      "description": "正規形フォーマットのバージョン。現行は 1 のみ。",
      "const": 1
    },
    "policies": {
      "description": "Policy の定義。name はドキュメント内で一意でなければならない。",
      "type": "array",
      "items": { "$ref": "#/$defs/policy" }
    },
    "attachments": {
      "description": "principal への Policy のアタッチ。同一 principal のエントリが複数ある場合、意味は和集合となる。",
      "type": "array",
      "items": { "$ref": "#/$defs/attachment" }
    }
  },
  "$defs": {
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "statements"],
      "properties": {
        "name": { "$ref": "#/$defs/policyName" },
        "statements": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/statement" }
        }
      }
    },
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effect", "actions"],
      "properties": {
        "effect": {
          "description": "この statement の効果。合成は常に deny-overrides で行われる。",
          "enum": ["allow", "deny"]
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/actionPattern" }
        }
      }
    },
    "attachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principal", "policies"],
      "properties": {
        "principal": { "$ref": "#/$defs/principal" },
        "policies": {
          "description": "アタッチする Policy 名のリスト。各要素は policies[].name のいずれかを参照しなければならない（参照整合性はスキーマ外の検証）。",
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/policyName" }
        }
      }
    },
    "policyName": {
      "description": "Policy の識別子。小文字英字始まり、英数字・アンダースコア・ハイフン。",
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "maxLength": 128,
      "examples": ["base-member", "post-editor", "suspended"]
    },
    "actionPattern": {
      "description": "action のパターン。`<resource>:<operation>` 形式で、各セグメントは小文字 snake_case のリテラルか `*` のいずれか（部分文字列パターンは不可）。`*` 単体は `*:*` の短縮形。",
      "type": "string",
      "pattern": "^(\\*|(\\*|[a-z][a-z0-9_]*):(\\*|[a-z][a-z0-9_]*))$",
      "maxLength": 128,
      "examples": ["post:view", "post:*", "*:view", "*"]
    },
    "principal": {
      "description": "principal の識別子。`<type>:<id>` 形式。type は小文字英字始まりの英数字・アンダースコア・ハイフン、id は空白と `*` を含まない 1 文字以上の文字列。パターンマッチは存在しないため `*` は使用できない。`rel:` は関係 principal の慣習的な prefix。",
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*:[^\\s*]+$",
      "maxLength": 256,
      "examples": ["user:42", "role:editor", "tenant:acme", "flag:suspended", "rel:owner"]
    }
  }
}
